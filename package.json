{
  "name": "study",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:next": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "smoke:accurate": "node --env-file=.env.local scripts/smoke-accurate-pipeline.mjs",
    "smoke:env": "node --env-file=.env.local scripts/smoke-env.mjs",
    "integration:accurate": "node --env-file=.env.local scripts/integration-analyze-accurate.mjs",
    "integration:accurate:local": "bash scripts/run-integration-accurate-local.sh",
    "flutter:pub-get": "flutter pub get --directory=flutter_app",
    "flutter:web": "cd flutter_app && flutter run -d chrome --dart-define=API_BASE_URL=http://localhost:3000",
    "flutter:run": "cd flutter_app && flutter run",
    "flutter:run:local": "cd flutter_app && flutter run --dart-define=API_BASE_URL=http://localhost:3000",
    "flutter:run:android-emulator": "cd flutter_app && flutter run --dart-define=API_BASE_URL=http://10.0.2.2:3000",
    "flutter:run:chrome": "npm run flutter:web",
    "flutter:run:macos": "cd flutter_app && flutter run -d macos --dart-define=API_BASE_URL=http://localhost:3000",
    "flutter:run:ios": "bash scripts/flutter-run-ios-simulator.sh",
    "flutter:release": "bash -lc 'source flutter_app/scripts/env-java.sh && bash flutter_app/scripts/release.sh'",
    "flutter:release:bump": "bash -lc 'source flutter_app/scripts/env-java.sh && bash flutter_app/scripts/release.sh --bump build'",
    "flutter:release:ios": "bash -lc 'source flutter_app/scripts/env-java.sh && bash flutter_app/scripts/release.sh ios'",
    "flutter:release:android": "bash -lc 'source flutter_app/scripts/env-java.sh && bash flutter_app/scripts/release.sh android'",
    "mobile:expo": "npm run start --prefix mobile",
    "capture:ipad-screens": "node scripts/capture-ipad-store-screens.mjs",
    "smoke:gpt5-kr": "node scripts/smoke-gpt5-vision-kr.mjs"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "jsxgraph": "^1.12.2",
    "katex": "^0.16.45",
    "mongodb": "^7.2.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.4",
    "react-to-print": "^3.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "playwright": "^1.50.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
