# 로컬: 이 파일을 복사해 `.env.local`로 저장하고 값만 채운다.
# 프로덕션: Vercel → Project → Settings → Environment Variables 에 동일 이름으로 등록한다.

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=

# 모드별 배포 이름(선택). 미설정 시 해당 모드는 `AZURE_OPENAI_DEPLOYMENT` 사용.
# 빠른 응답: 예) gpt-4o-mini / gpt-4.1-mini 등 가벼운 비전 배포
# AZURE_OPENAI_DEPLOYMENT_FAST=
# 밸런스: 예) gpt-4o
# AZURE_OPENAI_DEPLOYMENT_BALANCED=
# 정확: 예) gpt-4o 또는 더 큰 모델 배포
# AZURE_OPENAI_DEPLOYMENT_ACCURATE=

# 선택 (미설정 시 서버 기본값 사용)
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

MONGODB_URI=

# 선택
# MONGODB_DB_NAME=math_lens_tutor
