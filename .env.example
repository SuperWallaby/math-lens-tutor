# 로컬: 이 파일을 복사해 `.env.local`로 저장하고 값만 채운다.
# 프로덕션: Vercel → Project → Settings → Environment Variables 에 동일 이름으로 등록한다.

# 예: https://YOUR_RESOURCE.cognitiveservices.azure.com (끝 슬래시 없어도 됨)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=

# 미설정 모드는 여기 배포 이름으로 폴백합니다.
AZURE_OPENAI_DEPLOYMENT=

# 모드별 배포 이름 (선택). Azure CLI 예:
#   az cognitiveservices account deployment list \
#     --name YOUR_ACCOUNT --resource-group YOUR_RG -o table
#
# 아래는 리소스 `manag-mojrkejw-eastus2` 에 실제로 배포된 이름 예시입니다.
# 빠른: 가벼운 배포 (예: trx-gpt-4-1-mini — 비전 미지원 시 trx-gpt-4-1-vision 로 변경)
AZURE_OPENAI_DEPLOYMENT_FAST=trx-gpt-4-1-mini
# 밸런스: **유사 문제 생성** 등 텍스트 JSON에 쓰는 배포 이름(비전은 `AZURE_OPENAI_DEPLOYMENT_VISION`).
# 같은 리소스만 쓰면 gpt-4.1 비전 등도 가능하지만, 한국 `gpt-5.4`를 쓰려면 아래 “밸런스 리전 오버레이”를 채워야 함.
AZURE_OPENAI_DEPLOYMENT_BALANCED=trx-gpt-4-1-vision
# 정확: 분석 결과 텍스트만 받아 **유사 문제 생성**(텍스트 전용). Pro/추론 모델 가능 (예: gpt-5.4-pro; 이미지 입력은 같은 API에서 안 될 수 있음)
AZURE_OPENAI_DEPLOYMENT_ACCURATE=gpt-5.4-pro

# 비전 전용(풀이 사진 OCR)·미설정 시 밸런스 → 빠름 → AZURE_OPENAI_DEPLOYMENT 순 폴백
# 예: 동일 리소스에 `gpt-5.4`(모델 2026-03-05) 또는 `gpt-4o`(2024-11-20) 배포
AZURE_OPENAI_DEPLOYMENT_VISION=gpt-5.4

# 선택: 설정 탭·API에서 고를 수 있는 배포 이름 허용 목록(쉼표). 비두면 위 단일 AZURE_* 배포 값에서 자동 후보 생성.
AZURE_OPENAI_VISION_DEPLOYMENT_OPTIONS=gpt-5.4,gpt-4o,trx-gpt-4-1-vision
# 텍스트 튜터·유사문제 등 (예: o4-mini 는 동일 리소스에 배포되어 있어야 함 — o1/o3-mini 는 신규 배포가 막힐 수 있음)
AZURE_OPENAI_TEXT_DEPLOYMENT_OPTIONS=o4-mini,gpt-5.4-pro,gpt-5.4,gpt-5.4-pro-2,trx-gpt-4-1-mini,trx-gpt-4-1-vision

# ----- 밸런스 모드만 한국 등 별도 리소스로 보내기 (GPT-5.4 KR 배포 이름 `gpt-5.4`) -----
# 확인: az cognitiveservices account deployment list -n TestAzResourceAi -g test-az-sb-1 -o table
# AZURE_OPENAI_DEPLOYMENT_BALANCED=gpt-5.4
# AZURE_OPENAI_BALANCED_REGIONAL_ENDPOINT=https://testazresourceai.cognitiveservices.azure.com
# AZURE_OPENAI_BALANCED_REGIONAL_API_KEY=<TestAzResourceAi 의 Key>
# Responses 규칙에 `gpt-5.4` 포함(예: ...,gpt-5.4 또는 gpt-5.4*,gpt-5*)

# ----- 한국 중부(koreacentral) `TestAzResourceAi` 전부 사용 시 (메인 게이트웨이 교체와 택일) -----
# 엔드포인트: 포털 또는 `az cognitiveservices account show -n TestAzResourceAi -g <RG> --query properties.endpoint -o tsv`
# 키는 해당 리소스의 Keys 탭. 아래 배포는 CLI 로 생성됨(용량 30 TPM 요청 기준).
# 이 리전 카탈로그에는 gpt-5.4-pro 가 없음 → 정확 모드는 배포 `gpt-5.4`(모델 gpt-5.4 / 2026-03-05, Responses·채팅 가능) 사용.
# 선택: 비전을 GPT-5 Chat 으로 쓸 때 배포 예시 `exp-kr-gpt-5`(gpt-5 / 2025-08-07). 동작 확인: `npm run smoke:gpt5-kr`
# AZURE_OPENAI_ENDPOINT=https://testazresourceai.cognitiveservices.azure.com
# AZURE_OPENAI_DEPLOYMENT_FAST=trx-kr-gpt-4-1-mini
# AZURE_OPENAI_DEPLOYMENT_BALANCED=trx-kr-gpt-4-1-vision
# AZURE_OPENAI_DEPLOYMENT_ACCURATE=gpt-5.4
# AZURE_OPENAI_DEPLOYMENT_VISION=trx-kr-gpt-4-1-vision

# 선택: 텍스트 JSON 호출만 Responses API 를 쓸 배포(쉼표 구분, 정확 이름). 접두 매칭은 끝에 * (예: gpt-5*)
# 미설정이면 이름에 `gpt-5` 가 들어가면 자동으로 Responses 사용.
# AZURE_OPENAI_RESPONSES_DEPLOYMENTS=gpt-5.4-pro,gpt-5.4-pro-2,gpt-5.4
#
# 선택: Responses API api-version 쿼리 문자열 / 추론 강도(low|medium|high)
# AZURE_OPENAI_RESPONSES_API_VERSION=preview
# AZURE_OPENAI_REASONING_EFFORT=medium

# 선택 (미설정 시 서버 기본값 사용)
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

MONGODB_URI=

# 선택
# MONGODB_DB_NAME=math_lens_tutor

# 프로덕션: Flutter Web 등 별도 도메인에서 /api 호출 시 (쉼표로 여러 개)
# 예: CORS_ORIGIN=https://your-app.web.app,https://your-app.firebaseapp.com

